# Server Configuration
NODE_ENV=development
PORT=3000

# Security
API_KEY=your-secure-api-key-here-change-in-production
CORS_ORIGIN=http://localhost:3000

# Puppeteer
PUPPETEER_ARGS=--no-sandbox --disable-setuid-sandbox

# Proxies (comma-separated)
PROXY_LIST=

# Redis & Database
REDIS_URL=
DB_URL=

# Feature Flags
ENABLE_TORRENT=true
ENABLE_MUSIC=true
ENABLE_SCRAPING=true
ENABLE_RSS=true
ENABLE_SSE=true
ENABLE_HOT_RELOAD=false

# Timeouts (ms)
DEFAULT_TIMEOUT=30000
SCRAPING_TIMEOUT=60000
TORRENT_TIMEOUT=120000
MUSIC_TIMEOUT=15000

# Logging
LOG_LEVEL=info

# Spotify Integration
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback
SPOTIFY_REFRESH_TOKEN=

# Last.fm
LASTFM_API_KEY=
LASTFM_API_SECRET=

# ListenBrainz
LISTENBRAINZ_TOKEN=

# AtProto/Bluesky
ATP_URI=https://bsky.social
ATP_IDENTIFIER=
ATP_PASSWORD=
